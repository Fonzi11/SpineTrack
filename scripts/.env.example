# SpineTrack runtime configuration (copy to .env or export in shell)
# Do not commit real secrets.

# Firebase Admin
SPINETRACK_FIREBASE_DB_URL=https://spinetrack-c3179-default-rtdb.firebaseio.com
SPINETRACK_SERVICE_ACCOUNT_PATH=./serviceAccount.json

# MQTT (HiveMQ Cloud)
SPINETRACK_MQTT_HOST=your-cluster.s1.eu.hivemq.cloud
SPINETRACK_MQTT_PORT=8883
SPINETRACK_MQTT_USERNAME=your-username
SPINETRACK_MQTT_PASSWORD=your-password
SPINETRACK_MQTT_CLIENT_ID=spinetrack_device
SPINETRACK_MQTT_KEEPALIVE=60

