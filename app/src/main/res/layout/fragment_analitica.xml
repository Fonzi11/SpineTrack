<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_cream"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/poppins_bold"
            android:text="Analítica"
            android:textColor="@color/text_dark"
            android:textSize="24sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:fontFamily="@font/poppins_regular"
            android:text="Patrones y tendencias de tu postura"
            android:textColor="@color/text_soft"
            android:textSize="13sp" />

        <!-- Loading -->
        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="@color/peach_primary"
            android:visibility="gone" />

        <!-- Error -->
        <TextView
            android:id="@+id/tv_error"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:fontFamily="@font/poppins_regular"
            android:padding="12dp"
            android:textColor="#F44336"
            android:textSize="13sp"
            android:visibility="gone" />

        <!-- Contenido -->
        <LinearLayout
            android:id="@+id/layout_contenido"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- ══════════════════════════════ -->
            <!-- Card 1: Heatmap por hora       -->
            <!-- ══════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/surface_white"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins_semibold"
                        android:text="¿En qué horas tienes peor postura?"
                        android:textColor="@color/text_dark"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:fontFamily="@font/poppins_regular"
                        android:text="ICP promedio por hora del día"
                        android:textColor="@color/text_soft"
                        android:textSize="12sp" />

                    <com.github.mikephil.charting.charts.BarChart
                        android:id="@+id/chart_heatmap"
                        android:layout_width="match_parent"
                        android:layout_height="180dp" />

                    <!-- Leyenda de colores -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:background="#4CAF50" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:layout_marginEnd="12dp"
                            android:fontFamily="@font/poppins_regular"
                            android:text="Bueno"
                            android:textColor="@color/text_soft"
                            android:textSize="11sp" />

                        <View
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:background="#FFC107" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:layout_marginEnd="12dp"
                            android:fontFamily="@font/poppins_regular"
                            android:text="Regular"
                            android:textColor="@color/text_soft"
                            android:textSize="11sp" />

                        <View
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:background="#F44336" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:fontFamily="@font/poppins_regular"
                            android:text="Malo"
                            android:textColor="@color/text_soft"
                            android:textSize="11sp" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_insight_hora"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="#FFF8F0"
                        android:fontFamily="@font/poppins_regular"
                        android:padding="10dp"
                        android:textColor="@color/text_medium"
                        android:textSize="12sp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ══════════════════════════════ -->
            <!-- Card 2: Tendencia semanal      -->
            <!-- ══════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/surface_white"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins_semibold"
                        android:text="Tendencia de tu ICP"
                        android:textColor="@color/text_dark"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:fontFamily="@font/poppins_regular"
                        android:text="Últimas 4 semanas con línea de regresión"
                        android:textColor="@color/text_soft"
                        android:textSize="12sp" />

                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/chart_tendencia"
                        android:layout_width="match_parent"
                        android:layout_height="200dp" />

                    <TextView
                        android:id="@+id/tv_insight_tendencia"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="#F8FFF8"
                        android:fontFamily="@font/poppins_semibold"
                        android:padding="10dp"
                        android:textSize="13sp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ══════════════════════════════════ -->
            <!-- Card 3: Sensibilidad vs ICP        -->
            <!-- ══════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/surface_white"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins_semibold"
                        android:text="Sensibilidad vs Calidad postural"
                        android:textColor="@color/text_dark"
                        android:textSize="15sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:fontFamily="@font/poppins_regular"
                        android:text="ICP promedio según desviación angular detectada"
                        android:textColor="@color/text_soft"
                        android:textSize="12sp" />

                    <com.github.mikephil.charting.charts.BarChart
                        android:id="@+id/chart_sensibilidad"
                        android:layout_width="match_parent"
                        android:layout_height="160dp" />

                    <TextView
                        android:id="@+id/tv_insight_sensibilidad"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="#F0F8FF"
                        android:fontFamily="@font/poppins_regular"
                        android:padding="10dp"
                        android:textColor="@color/text_medium"
                        android:textSize="12sp" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Botón refrescar -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_refrescar"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:fontFamily="@font/poppins_semibold"
                android:text="Actualizar analítica"
                app:cornerRadius="14dp"
                app:strokeColor="@color/peach_primary" />

        </LinearLayout>

        <!-- ═══════════════════════════════════════════════ -->
        <!-- Estado — Error de conexión / Desconexión       -->
        <!-- ═══════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/layout_desconexion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/bg_state_card"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp"
            android:visibility="gone">

            <TextView
                android:id="@+id/tv_estado_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📡"
                android:textSize="72sp" />

            <TextView
                android:id="@+id/tv_estado_titulo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:fontFamily="@font/poppins_bold"
                android:gravity="center"
                android:text="Error de conexión"
                android:textColor="@color/text_dark"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/tv_mensaje_desconexion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/poppins_regular"
                android:gravity="center"
                android:lineSpacingMultiplier="1.4"
                android:text="Parece que hay un problema de conexión. Verifica tu sesión e intenta nuevamente."
                android:textColor="@color/text_soft"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_reintentar_conexion"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/poppins_semibold"
                android:text="Reintentar"
                app:backgroundTint="@color/peach_primary"
                app:cornerRadius="14dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>